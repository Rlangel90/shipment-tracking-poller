# Copy to .env for local runs. Never commit the real .env file.

# Postgres warehouse holding the tracked_shipments table
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/warehouse

# Base URL of the mock carrier tracking API (see mock_carrier/server.py)
CARRIER_API_URL=http://localhost:8300

# Comma-separated shipment_ids to force a re-poll of, bypassing the
# terminal/staleness skip rules. Leave blank for a normal run.
FORCE_REPOLL_IDS=
